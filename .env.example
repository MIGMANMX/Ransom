# Copia este archivo a ".env" (que NUNCA se sube a git) y completa los valores reales.

# API key de ransomware.live PRO (https://www.ransomware.live/my)
RANSOMWARE_LIVE_API_KEY=

# Webhook del feed global (Teams > Workflows > "Post to a channel when a webhook request is received")
TEAMS_WEBHOOK_GLOBAL=

# Webhooks por país (deja vacío el que no quieras usar). Mismo orden que
# config/settings.yaml -> countries.order.
